# Rate limit tuning
# Window size for request counting (ms)
RATE_LIMIT_WINDOW_MS=60000
# Max requests allowed per window per key(IP)
RATE_LIMIT_MAX_REQUESTS=8
# Cooldown period after limit exceeded (ms)
RATE_LIMIT_COOLDOWN_MS=30000

# Logging
# Set warn to suppress info-level logs
LOG_LEVEL=info

